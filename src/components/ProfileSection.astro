---
import { Image } from "astro:assets";
import SelfImage from "../assets/self.jpg";
import XIcon from "../assets/x-icon.svg";
import GithubIcon from "../assets/github-icon.svg";
import ZennIcon from "../assets/zenn-icon.svg";
import SoundCloudIcon from "../assets/soundcloud-icon.png";

const socialButtons = [
  {
    name: "x",
    URL: "https://twitter.com/komura_c",
    imgSrc: XIcon,
  },
  {
    name: "github",
    URL: "https://github.com/komura-c",
    imgSrc: GithubIcon,
  },
  {
    name: "zenn",
    URL: "https://zenn.dev/komura_c",
    imgSrc: ZennIcon,
  },
  {
    name: "soundcloud",
    URL: "https://soundcloud.com/komura_c",
    imgSrc: SoundCloudIcon,
  },
];
---

<div id="top" class="bg-top">
  <div class="profile-card">
    <div class="profile-card__img-wrapper">
      <Image
        src={SelfImage}
        width={280}
        height={280}
        format="webp"
        alt="komura-c"
        class="profile-card__img"
        loading="eager"
      />
    </div>
    <div class="profile-card__info">
      <h1 class="profile-card__name">komura-c / Yuki Ishii</h1>
      <div class="profile-card__description">
        <p>Work: Software Engineer</p>
        <p>Interests: Web Frontend / 音楽 / 音声</p>
        <p>
          Contacts:
          <a
            href="https://twitter.com/komura_c"
            target="_blank"
            rel="noopener noreferrer">X</a
          >
          /
          <a
            href="mailto:komura_334@yahoo.co.jp"
            target="_blank"
            rel="noopener noreferrer">メール</a
          >
        </p>
      </div>
      <div class="social-buttons">
        {
          socialButtons.map((socialButton) => (
            <a
              href={socialButton.URL}
              target="_blank"
              rel="noopener noreferrer"
              class={"social-buttons__link " + socialButton.name}
            >
              <Image
                src={socialButton.imgSrc}
                width={80}
                height={80}
                format="webp"
                alt={socialButton.name}
              />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</div>

<style>
  .bg-top {
    position: relative;
    background-color: #fbbf5d;
    height: 450px;
    padding-top: 8em;
    z-index: 1;
  }
  .bg-top::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 80%;
    height: 50%;
    background-color: #f4f4f7;
    transform: skewY(-6deg);
    z-index: -1;
  }

  .profile-card {
    max-width: 600px;
    background-color: #fff;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 8px 40px 0 rgba(0, 0, 0, 0.08);
    border-radius: 4px;
  }
  .profile-card__img {
    width: 140px;
    height: 140px;
    border-radius: 50%;
  }
  .profile-card__img-wrapper {
    width: 150px;
    height: 150px;
    margin-top: -70px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(
      -45deg,
      rgb(255, 166, 73),
      rgb(247, 100, 91),
      rgb(128, 94, 212)
    );
    box-shadow: 0 8px 40px 0 rgba(0, 0, 0, 0.08);
  }
  .profile-card__info {
    padding: 16px;
  }
  .profile-card__name {
    text-align: center;
    font-size: 28px;
    margin-bottom: 16px;
  }
  .profile-card__description {
    padding: 16px 24px;
    background-color: #339af0;
    color: #fff;
    border-radius: 10px;
    letter-spacing: 1.2px;
    margin-bottom: 16px;
  }
  .profile-card__description a {
    color: #fff;
    font-weight: bold;
    text-decoration: underline;
    transition-duration: 0.3s;
  }
  .profile-card__description a:hover {
    opacity: 0.5;
  }

  .social-buttons {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .social-buttons__link {
    width: 40px;
    height: 40px;
    margin-right: 12px;
    transition-duration: 0.3s;
  }
  .social-buttons__link:hover {
    opacity: 0.5;
  }
  .social-buttons__link img {
    width: 100%;
    height: 100%;
  }
  .social-buttons__link.x {
    background-color: #000;
    border-radius: 50%;
    padding: 8px;
  }
  .social-buttons__link.zenn {
    padding: 2px;
  }
  .social-buttons__link.soundcloud img {
    border-radius: 50%;
  }
</style>
